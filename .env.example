# Convex CLI / frontend runtime.
# `npx convex dev` usually writes these to `.env.local` for you.
CONVEX_DEPLOYMENT=dev:your-deployment-name
VITE_CONVEX_URL=https://your-deployment.convex.cloud
VITE_SITE_URL=https://implantium.kz

# Convex deployment environment variables.
# Set these with `npx convex env set KEY VALUE` or in the Convex dashboard.
# Do not expose these as `VITE_` variables.
IMPLANTIUM_ADMIN_AUTH_SALT=replace-with-a-long-random-string
IMPLANTIUM_ADMIN_PASSWORD_HASH=replace-with-sha256-of-salt-colon-password
IMPLANTIUM_SEED_SECRET=replace-with-a-long-random-seed-secret

# Example hash generation:
# node -e "const crypto=require('crypto'); const salt='YOUR_SALT'; const password='YOUR_PASSWORD'; console.log(crypto.createHash('sha256').update(`${salt}:${password}`).digest('hex'))"
